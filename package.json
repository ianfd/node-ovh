{
  "name": "@accelome/node-ovh",
  "version": "1.0.0",
  "description": "Community Node.js wrapper for the OVH APIs",
  "author": "OVH SAS",
  "license": "MIT",
  "keywords": [
    "OVH",
    "API",
    "REST",
    "api.ovh.com"
  ],
  "files": [
    "dist",
    "schemas",
    "examples"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./v2": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ianfd/node-ovh.git"
  },
  "bugs": {
    "url": "https://github.com/ianfd/node-ovh/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "bun run build:v2",
    "build:v2": "tsc -p tsconfig.json",
    "typecheck": "bun run typecheck:v2",
    "typecheck:v2": "tsc -p tsconfig.v2-tests.json",
    "generate:v2": "node scripts/generate-v2-client.js",
    "test:v2": "bun run build:v2 && bun run typecheck:v2 && node --test tests/v2/*.test.js tests/v2/*.integration.test.js",
    "test": "bun run test:v2"
  }
}
